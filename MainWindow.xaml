<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExpenseTracker"
        xmlns:vm="clr-namespace:ExpenseTracker.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="Expense Tracker" Height="800" Width="1200"
        Icon="Resources/expense-icon.png">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- Top Section: Expense List and Input Form -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: List and Summary -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" 
                          ItemsSource="{Binding Expenses}" 
                          SelectedItem="{Binding SelectedExpense}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="Auto"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="1" Text="Monthly Summary" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox Grid.Row="2" 
                         Text="{Binding MonthSummary, Mode=OneWay}" 
                         IsReadOnly="True" 
                         Height="100" 
                         VerticalScrollBarVisibility="Auto" 
                         AcceptsReturn="True"/>
            </Grid>

            <!-- Right Column: Input Form -->
            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Expense Details" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <TextBlock Text="Description:"/>
                    <TextBox Text="{Binding DescriptionInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="2"/>

                    <TextBlock Text="Amount:"/>
                    <TextBox Text="{Binding AmountInput, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Margin="0,0,0,10" Padding="2"/>

                    <TextBlock Text="Date:"/>
                    <DatePicker SelectedDate="{Binding DateInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Vertical">
                        <Button Command="{Binding AddCommand}" Content="Add Expense" Margin="0,0,0,5" Padding="5"/>
                        <Button Command="{Binding UpdateCommand}" Content="Update Selected" Margin="0,0,0,5" Padding="5"/>
                        <Button Command="{Binding DeleteCommand}" Content="Delete Selected" Margin="0,0,0,5" Padding="5" Background="LightPink"/>
                        <Button Command="{Binding ClearSelectionCommand}" Content="Clear Selection / Reset Form" Margin="0,10,0,5" Padding="5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom Section: Charts -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Pie Chart: Expense Breakdown -->
            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Expense Breakdown by Category" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding PieChartSeries}" LegendPosition="Right"/>
                </Grid>
            </Border>

            <!-- Line Chart: Spending Trends -->
            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" CornerRadius="5" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Monthly Spending Trend" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding LineChartSeries}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
